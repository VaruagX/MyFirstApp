{
  "expo": {
    "name": "MyFirstApp",
    "slug": "MyFirstApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pic1.jpg",
    "scheme": "myfirstapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/pic1.jpg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/pic1.jpg",
        "monochromeImage": "./assets/images/pic1.jpg"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MyFirstApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/pic1.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/pic1.jpg",
            "imageWidth": 76
          }
        }
      ],
      "expo-asset",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b17d4722-14ce-46aa-ac9d-00abdf2ded42"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b17d4722-14ce-46aa-ac9d-00abdf2ded42"
    }
  }
}
